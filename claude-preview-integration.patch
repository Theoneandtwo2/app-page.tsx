+# ============================================================================
+# Gol Homes Portal — environment variables
+# ----------------------------------------------------------------------------
+# Copy this file to .env.local and fill in real values for local development.
+# In production, set these in Vercel Project Settings → Environment Variables.
+# Do NOT commit .env or .env.local — they're in .gitignore.
+# ============================================================================
+
+# --- Supabase (required) ---
+NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
+NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
+SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
+
+# --- Admin gate (required) ---
+# The single email allowed into /dashboard. Any other email that signs in
+# will be shown an "Access denied" card.
+ADMIN_EMAIL=sajed@golhomes.com
+
+# --- Email (one provider — pick whichever is available) ---
+# Optional explicit override. If unset, the helper picks the first provider
+# below that has its required vars set, in this order: smtp, sendgrid, resend.
+# EMAIL_PROVIDER=smtp
+
+# Used as the From: address by whichever provider is active.
+# EMAIL_FROM="Gol Homes Portal <portal@golhomes.com>"
+
+# --- Option A: SMTP (SMTP2GO free, Google Workspace, etc.) ---
+# SMTP_HOST=mail.smtp2go.com
+# SMTP_PORT=587
+# SMTP_USER=your-smtp-user
+# SMTP_PASS=your-smtp-pass
+# SMTP_SECURE=false
+
+# --- Option B: SendGrid ---
+# SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxx
+# SENDGRID_FROM_EMAIL="Gol Homes Portal <portal@golhomes.com>"
+
+# --- Option C: Resend ---
+# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxx
+
+# If NO email provider is configured, the app keeps working — submissions
+# and status updates succeed but no email is sent. Logs warn each time.
